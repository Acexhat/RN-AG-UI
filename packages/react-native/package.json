{
  "name": "@ag-ui/react-native",
  "version": "0.0.1",
  "description": "AG-UI React Native renderer — AgentRenderer, hooks, and default components",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ag-ui/core": "workspace:*",
    "@ag-ui/client": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "devDependencies": {
    "@types/react": "^19.1.1",
    "typescript": "^5.4.5"
  },
  "files": ["dist"],
  "sideEffects": false
}
