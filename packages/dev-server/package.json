{
  "name": "@ag-ui/dev-server",
  "version": "0.0.1",
  "description": "AG-UI development server — local mock backend for testing without a real AI service",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ag-ui-dev": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@ag-ui/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  }
}
